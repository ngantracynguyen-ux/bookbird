# --- LLM (GreenNode AI Platform, OpenAI-compatible) ---
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# Model agent đang dùng (reasoning model). Đổi sang model khác trên MaaS nếu muốn nhanh hơn.
LLM_MODEL=minimax/minimax-m2.5

# --- SMTP gửi mail xác nhận (giống report-agent) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_USE_TLS=true

# --- Google Calendar (tuỳ chọn) ---
# Để TRỐNG => agent chạy chế độ MOCK (bộ nhớ tạm).
# Cách 1: nội dung JSON service account HOẶC đường dẫn file
GOOGLE_SA_CREDENTIALS=
# Cách 2 (khuyên dùng khi deploy AgentBase — env không nhận JSON nhiều dòng):
# base64 của file service account JSON  (xem GCAL-SETUP.md)
GOOGLE_SA_CREDENTIALS_B64=
# Calendar ID của từng phòng (chỉ cần khi dùng Calendar thật)
ROOM_A_CALENDAR_ID=
ROOM_B_CALENDAR_ID=
ROOM_C_CALENDAR_ID=
ROOM_D_CALENDAR_ID=
ROOM_E_CALENDAR_ID=
ROOM_F_CALENDAR_ID=
# Sơ đồ phòng (tuỳ chọn, URL ảnh)
ROOM_A_DIAGRAM_URL=
ROOM_B_DIAGRAM_URL=
ROOM_C_DIAGRAM_URL=
ROOM_D_DIAGRAM_URL=
ROOM_E_DIAGRAM_URL=
ROOM_F_DIAGRAM_URL=

# --- Memory (tuỳ chọn) — ghi nhớ thói quen người dùng qua GreenNode Memory ---
# Có MEMORY_ID => dùng AgentBaseMemoryEvents (bền vững, chia sẻ giữa replica); trống => InMemorySaver.
MEMORY_ID=
MEMORY_STRATEGY_ID=default

# --- Chữ ký mail mặc định (tuỳ chọn) ---
ORG_NAME=ZaloPay Accounting/Finance
ORG_DOMAIN=zalopay.vn

# --- Google Sign-In (tuỳ chọn) — đăng nhập bằng tài khoản Google ---
GOOGLE_OAUTH_CLIENT_ID=

# --- Nhắc trước cuộc họp (phút), mặc định 15 ---
REMINDER_MINUTES=15
